# SQLite database file (path relative to the pos-admin project root)
DATABASE_URL="file:./prisma/dev.db"

# JWT (HS256) — REST auth + Socket.io; also used as Better Auth secret if BETTER_AUTH_SECRET is unset
JWT_SECRET="replace_with_a_long_random_secret_at_least_32_characters"

# Better Auth (admin email OTP). Falls back to JWT_SECRET when unset (must be ≥32 chars).
# BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:3000"

# Resend — admin OTP emails (optional in dev; OTP is printed to the server console instead)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL="FutureLink <noreply@yourdomain.com>"

# Comma-separated origins for Socket.io CORS, or * for dev
SOCKET_CORS_ORIGINS="http://localhost:3000,http://localhost:8081"

# Default tenant id embedded in JWT (single-restaurant until a Restaurant model exists)
DEFAULT_RESTAURANT_ID="default"
